# Copy to .env and fill in real values.
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/tesca
GEMINI_API_KEY=your-gemini-api-key

# Clerk (production auth). Optional locally if DEV_AUTH_BYPASS=true.
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Dev-only: skip auth and treat every request as DEV_USER_ID. Never in prod.
DEV_AUTH_BYPASS=false
DEV_USER_ID=dev-user

# Optional — leave unset locally to skip S3 uploads.
S3_BUCKET=
AWS_REGION=us-east-1

# Browser origin allowed to call the API (the frontend dev server).
FRONTEND_ORIGIN=http://localhost:5173
